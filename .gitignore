# Everything below is generated, local-only, or not required to run the tool.
# What ships: threat_monitor.py, tm/, tests/, assets (wav/ico), requirements,
# build spec + manifest, docs (README, how_to) and community files.

# -- Python environment & caches ---------------------------------------------
.venv/
__pycache__/
*.py[cod]
.pytest_cache/

# -- PyInstaller build artifacts ----------------------------------------------
build/
dist/
*.exe
*.spec.bak

# -- Data generated by the app at runtime (user-specific) ---------------------
threat_config.json
threat_monitor.log*

# -- Local AI/editor tooling (not part of the project) -------------------------
.claude/
.codex/
.agents/
docs/superpowers/

# -- OS noise ------------------------------------------------------------------
Thumbs.db
.DS_Store
